{
  "$schema": "https://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "backgroundImage": {
    "url": "https://eva.useaima.com/eva-og.png",
    "fillMode": "Cover",
    "horizontalAlignment": "Center",
    "verticalAlignment": "Center"
  },
  "body": [
    {
      "type": "Container",
      "bleed": true,
      "style": "default",
      "items": [
        {
          "type": "TextBlock",
          "text": "${title}",
          "weight": "Bolder",
          "size": "Large",
          "color": "Dark"
        },
        {
          "type": "TextBlock",
          "text": "${subtitle}",
          "wrap": true,
          "spacing": "Small",
          "color": "Dark"
        },
        {
          "type": "FactSet",
          "spacing": "Medium",
          "facts": [
            {
              "title": "${statusLabel}",
              "value": "${statusValue}"
            },
            {
              "title": "${focusLabel}",
              "value": "${focusValue}"
            },
            {
              "title": "${streakLabel}",
              "value": "${streakValue}"
            }
          ]
        }
      ]
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "${ctaLabel}",
      "verb": "open-chat"
    },
    {
      "type": "Action.Execute",
      "title": "${secondaryCtaLabel}",
      "verb": "open-dashboard"
    }
  ]
}
